		"access": "public"
	},
	"scripts": {
		"build": "tsc",
		"check": "biome check .",
		"format": "biome format --write .",
		"test": "vitest run"
	},
	"dependencies": {
		"@earendil-works/pi-coding-agent": "latest"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.15",
		"@types/node": "^24.0.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.6"
	}
