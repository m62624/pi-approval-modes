{
	"name": "@m62624/approval-modes",
	"version": "1.0.0",
	"description": "Approval modes for pi: YOLO, Read-Only, Strict",
	"keywords": [
		"pi-package"
	],
	"type": "module",
	"main": "src/index.ts",
	"pi": {
		"extensions": [
			"src/index.ts"
		]
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/m62624/pi-approval-modes.git"
	},
	"license": "MIT",
